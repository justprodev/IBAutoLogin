<configuration>
    <appender name="console" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss} %-5p [%t] %c{1}:%L - %m%n</pattern>
        </encoder>
    </appender>

    <root level="TRACE">
        <appender-ref ref="console" />
    </root>
</configuration>
